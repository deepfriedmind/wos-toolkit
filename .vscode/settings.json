{
  "common-intellisense.ui": [
    "primevue4"
  ],
  "cSpell.ignorePaths": [
    ".git/{index,*refs,*HEAD}",
    ".git/{info,lfs,logs,refs,objects}/**",
    ".vscode",
    ".vscode-insiders",
    "CHANGELOG.md",
    "node_modules",
    "package-lock.json",
    "vscode-extension"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never",
    "source.sortImports": "never"
  },
  "editor.formatOnPaste": false,
  "editor.formatOnSave": false,
  "editor.formatOnType": false,
  "editor.quickSuggestions": {
    "strings": true
  },
  "eslint.rules.customizations": [
    {
      "fixable": true,
      "rule": "*",
      "severity": "off"
    }
  ],
  "eslint.runtime": "node",
  "eslint.validate": [
    "astro",
    "css",
    "gql",
    "graphql",
    "html",
    "javascript",
    "javascriptreact",
    "json",
    "json5",
    "jsonc",
    "less",
    "markdown",
    "pcss",
    "postcss",
    "scss",
    "toml",
    "typescript",
    "typescriptreact",
    "vue",
    "xml",
    "yaml"
  ],
  "explorer.excludeGitIgnore": true,
  "explorerExclude.backup": {},
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "files.readonlyInclude": {
    "**/.stylelintcache": true,
    "**/auto-imports.d.ts": true,
    "**/components.d.ts": true,
    ".eslintcache": true,
    ".nuxt": true,
    ".output": true,
    "node_modules/**/*": true,
    "pnpm-lock.yaml": true
  },
  "git.inputValidationSubjectLength": 72,
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "nuxtr.defaultPackageManager": "pnpm",
  "nuxtr.piniaFiles.defaultTemplate": "setup",
  "nuxtr.vueFiles.firstTag": "script",
  "nuxtr.vueFiles.script.defaultLanguage": "ts",
  "nuxtr.vueFiles.script.type": "setup",
  "nuxtr.vueFiles.style.addStyleTag": false,
  "nuxtr.vueFiles.style.defaultLanguage": "postcss",
  "peacock.color": "#254166",
  "prettier.enable": false,
  "search.exclude": {
    ".github/docs": true,
    "pnpm-lock.yaml": true
  },
  "tailwindCSS.classAttributes": [
    "appear-active-class",
    "appear-from-class",
    "appear-to-class",
    "class",
    "enter-active-class",
    "enter-from-class",
    "enter-to-class",
    "input-class",
    "leave-active-class",
    "leave-from-class",
    "leave-to-class"
  ],
  "tailwindCSS.experimental.classRegex": [
    "tw\\('(.*?)'\\)",
    "tw\\(\\s*('(.*?)'|\"(.*?)\")\\s*\\)",
    "tw`(.*?)`",
    [
      "twJoin\\(([^)]*)\\)",
      "[\"'`]([^\"'`]*)[\"'`]"
    ],
    [
      "(?:twMerge|twJoin)\\(([^;]*)[\\);]",
      "[`'\"`]([^'\"`;]*)[`'\"`]"
    ]
  ],
  "tailwindCSS.rootFontSize": 16,
  "workbench.colorCustomizations": {
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#33598b",
    "tab.activeBorder": "#33598b",
    "titleBar.activeBackground": "#254166",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#25416699",
    "titleBar.inactiveForeground": "#e7e7e799"
  }
}
